{
  "name": "Zip",
  "type": "object",
  "properties": {
    "zip_code": {
      "type": "string"
    },
    "latitude": {
      "type": "number"
    },
    "longitude": {
      "type": "number"
    },
    "city": {
      "type": "string"
    },
    "state": {
      "type": "string"
    },
    "cached_at": {
      "type": "string",
      "format": "date-time"
    },
    "description": {
      "type": "string",
      "description": "Optional notes about this zip code area",
      "maxLength": 1000
    }
  },
  "required": [
    "zip_code",
    "latitude",
    "longitude"
  ],
  "rls": {
    "create": {
      "user_condition": {
        "role": "admin"
      }
    },
    "read": {},
    "update": {
      "user_condition": {
        "role": "admin"
      }
    },
    "delete": {
      "user_condition": {
        "role": "admin"
      }
    }
  }
}